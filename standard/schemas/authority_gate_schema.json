{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuthorityGateEvent",
  "type": "object",
  "properties": {
    "event_type": { "type": "string", "enum": ["authority_gate"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "node_id": { "type": "string" },
    "action_requested": { "type": "string" },
    "human_decision": { "type": "string", "enum": ["approve", "deny"] },
    "decision_reason": { "type": "string" },
    "operator_contract_clause": { "type": "string" },
    "giu_burn": { "type": "number" }
  },
  "required": [
    "event_type",
    "timestamp",
    "node_id",
    "action_requested",
    "human_decision",
    "decision_reason",
    "operator_contract_clause",
    "giu_burn"
  ],
  "additionalProperties": false
}
