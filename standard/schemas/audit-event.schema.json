{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baselayeros.org/schemas/audit-event.schema.json",
  "title": "Audit Event",
  "description": "Schema for BaseLayerOS audit log events.",
  "type": "object",
  "required": [
    "event_id",
    "timestamp",
    "actor",
    "context",
    "event_type",
    "payload",
    "prev_hash",
    "event_hash"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Unique identifier for the event."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the event occurred."
    },
    "actor": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["workflow", "module", "system", "user"],
          "description": "Type of actor responsible for the event."
        },
        "id": {
          "type": "string",
          "description": "Identifier of the actor."
        }
      }
    },
    "context": {
      "type": "object",
      "required": ["workflow_id", "workflow_version", "trace_id"],
      "properties": {
        "workflow_id": {
          "type": "string",
          "description": "Workflow identifier."
        },
        "workflow_version": {
          "type": "string",
          "description": "Workflow version."
        },
        "trace_id": {
          "type": "string",
          "description": "Replay trace identifier."
        },
        "step_id": {
          "type": ["string", "null"],
          "description": "Step identifier, if applicable."
        }
      }
    },
    "event_type": {
      "type": "string",
      "description": "Machine-readable event type."
    },
    "payload": {
      "type": "object",
      "description": "Event-specific structured data."
    },
    "prev_hash": {
      "type": ["string", "null"],
      "description": "Hash of the previous event in the log."
    },
    "event_hash": {
      "type": "string",
      "description": "SHA-256 hash of this event."
    }
  }
}
