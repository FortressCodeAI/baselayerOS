{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baselayeros.org/schemas/compliance-pack-interface.schema.json",
  "title": "Compliance Pack Manifest",
  "description": "Schema for BaseLayerOS compliance pack manifests.",
  "type": "object",
  "required": ["compliance_pack"],
  "properties": {
    "compliance_pack": {
      "type": "object",
      "required": [
        "id",
        "name",
        "version",
        "owner",
        "description",
        "scope",
        "invariants",
        "checks",
        "actions"
      ],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "string" },
        "owner": { "type": "string" },
        "description": { "type": "string" },

        "scope": {
          "type": "object",
          "required": ["workflows", "modules"],
          "properties": {
            "workflows": {
              "type": "array",
              "items": { "type": "string" }
            },
            "modules": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },

        "invariants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description", "severity"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["info", "warning", "error", "critical"]
              }
            }
          }
        },

        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description", "when", "uses_invariants"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "when": { "type": "string" },
              "uses_invariants": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },

        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description", "on_violation"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "on_violation": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
